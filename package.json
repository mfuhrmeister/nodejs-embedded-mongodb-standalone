    "globals": "^16.4.0",
    "gulp": "^5.0.1",
    "jasmine": "^5.13.0",
    "jasmine-reporters": "^2.5.2",
    "require-dir": "^1.2.0",
    "rewire": "^9.0.1"
  },
  "dependencies": {
    "extract-zip": "^2.0.1",
    "getos": "^3.2.1",
    "npmlog": "^7.0.1",
    "ramda": "^0.32.0",
    "sprintf-js": "^1.1.3",
    "tar": "^7.5.20"
  },
  "overrides": {
