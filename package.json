    "test": "./node_modules/gulp/bin/gulp.js test",
    "dax": "node bin/dax",
    "start": "node bin/start",
    "stop": "node bin/stop"
  },
  "engines": {
    "node": ">=18"
  },
  "main": "lib/nems.js",
