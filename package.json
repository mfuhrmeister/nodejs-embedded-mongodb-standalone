{
  "name": "nems",
  "version": "3.0.1",
  "description": "nems is a native Promise-based embedded MongoDB distribution library that downloads an appropriate MongoDB build and runs it standalone for integration and functional tests.",
  "homepage": "https://github.com/mfuhrmeister/nodejs-embedded-mongodb-standalone",
  "keywords": [
    "mongo",
    "mongod",
    "mongodb",
    "embedded",
    "standalone",
    "download",
    "promise",
    "node.js"
  ],
  "author": {
    "name": "Marcus Fuhrmeister",
    "email": "marcus.fuhrmeister@googlemail.com",
    "url": "https://github.com/mfuhrmeister"
  },
  "license": "MIT",
  "files": [
    "lib",
    "bin"
  ],
  "scripts": {
    "clean": "node scripts/clean.js",
    "lint": "eslint \"./lib/**/*.js\" \"./test/**/*.js\" \"./scripts/**/*.js\"",
    "unit": "node scripts/run-jasmine.js test/unit target/test-reports/unit",
    "functional": "node scripts/run-jasmine.js test/functional target/test-reports/functional",
    "build": "npm run clean && npm run lint && npm run unit && npm run functional",
    "test": "npm run lint && npm run unit && npm run functional",
    "release:patch": "npm version patch -m \"release (nems): v%s\" && npm publish",
    "release:minor": "npm version minor -m \"release (nems): v%s\" && npm publish",
    "release:major": "npm version major -m \"release (nems): v%s\" && npm publish",
    "dax": "node bin/dax.js",
    "start": "node bin/start.js",
    "stop": "node bin/stop.js"
  },
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "main": "lib/nems.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/mfuhrmeister/nodejs-embedded-mongodb-standalone.git"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.5",
    "globals": "^16.4.0",
    "jasmine": "^5.13.0",
    "jasmine-reporters": "^2.5.2"
  },
  "dependencies": {
    "extract-zip": "^2.0.1",
    "getos": "^3.2.1",
    "tar": "^7.5.20"
  },
  "overrides": {
    "async": "^2.6.4",
    "graceful-fs": "^4.2.11",
    "lodash": "^4.18.1",
    "minimatch": "^3.1.5"
  }
}
